# --- Core API keys ---

# Resend API key — sends the daily digest and inbound-agent replies (required)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Perplexity API key — generates the daily market insights section (required for the digest)
PERPLEXITY_API_KEY=pplx-xxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic API key — powers the inbound forward-to-LLM agent (required for /api/email/inbound)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Resend webhook signing secret for the inbound email webhook (required for /api/email/inbound)
RESEND_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx

# --- Daily market digest ---

# Comma-separated recipient addresses for the daily digest (REQUIRED — the cron returns 500 without it)
DIGEST_RECIPIENTS=you@example.com,teammate@example.com

# Digest sender address — must be on a Resend-verified domain (falls back to onboarding@resend.dev, Resend's shared testing sender)
EMAIL_FROM=digest@example.com

# Display name for the digest sender
EMAIL_FROM_NAME=Market Brief

# Bearer token guarding /api/cron/send-daily-email and /api/email/send (recommended in production)
CRON_SECRET=some-long-random-string

# Base URL the digest generator uses to call its own /api/solana/token-data endpoint (defaults to http://localhost:3000)
NEXT_PUBLIC_API_URL=http://localhost:3000

# --- Inbound email agent ---

# Comma-separated senders allowed to trigger the inbound agent — THE AUTH BOUNDARY (REQUIRED; unset/empty = deny all)
ALLOWED_EMAIL_SENDERS=you@example.com

# Reply-from address for the inbound agent — must be on a Resend-verified domain (REQUIRED for /api/email/inbound)
AGENT_EMAIL_FROM=assistant@example.com

# Display name for the inbound agent's replies
AGENT_EMAIL_FROM_NAME=Assistant

# On a catch-all receiving domain, only mail addressed to this address triggers the agent (optional)
AGENT_INBOUND_ADDRESS=assistant@example.com

# How the agent's system prompt refers to you (optional; defaults to "the operator")
OPERATOR_NAME=the operator

# --- Email branding (optional) ---

# Header logo for the digest email — a path under public/ (e.g. logo.png) or an absolute path; unset = text-only header
LOGO_PATH=

# Footer links as a JSON array of {label,url} objects; unset = no footer links
FOOTER_LINKS=[{"label":"Home","url":"https://example.com"}]
